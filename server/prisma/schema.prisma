
generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

// Ejecutar con: pnpm prisma db seed


datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}



// Enums

enum Gender {
  MASCULINO
  FEMENINO
}

enum Dicipules {
  SI
  NO
}

enum LevelDicipules {
  I
  II
  III
  IV
}

enum WayPay {
  EFECTIVO
  TRANSFERENCIA
}

enum Pay {
  PAGO
  DEBE
}

enum Role {
  USER
  LIDER
  ADMIN
}



// tablas 

model User {
  id              String    @id @default(uuid())
  email           String?    @unique
  name            String?
  number          String?    @unique
  password        String?
  happybirth      DateTime?
  gender          Gender?
  isActive        Boolean   @default(true)
  baptized        Boolean   @default(false)
  dicipules       Dicipules @default(SI)
  role            Role      @default(USER) // valores posibles: user, lider, admin
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  address         String?
  age             Int?
  hobbies         String?
  dreams          String?
  job             String?
  vulnerable_area String?
  members         Members[]    // un User puede tener muchos Members
  usersEvent      UsersEvent[] // Un usuario puede ir a muchos eventos
}

model Groups {
  id          String       @id @default(uuid())
  name        String       @unique
  description String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  members     Members[]
  sessions    Session[]
  forumPosts  ForumPost[]
}

model ForumPost {
  id        String   @id @default(uuid())
  groupId   String
  group     Groups   @relation(fields: [groupId], references: [id], onDelete: Cascade)
  title     String
  content   String   @db.Text
  authorId  String?
  authorName String?  // nombre para mostrar si no hay user
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("forum_posts")
}

model Members {
  id             String         @id @default(uuid())
  userId         String
  user           User           @relation(fields: [userId], references: [id])
  groupId        String
  group          Groups         @relation(fields: [groupId], references: [id])
  levelDicipules LevelDicipules
  joinedAt       DateTime       @default(now())

  @@unique([userId, groupId]) // un usuario solo puede estar una vez en un grupo
}

model UsersEvent {
  id            String    @id @default(uuid())
  userId        String?              
  eventId       String               
  name          String
  email         String
  dateBorn      DateTime
  wayPay        WayPay?
  phone         String?
  paymentAmount Float     @default(0)
  payStatus     Pay       @default(DEBE)
  createdAt     DateTime  @default(now())
  hasSiblings   Boolean   @default(false)

  user  User?  @relation(fields: [userId], references: [id])
  event Event  @relation(fields: [eventId], references: [id])

  @@map("users_event")
}

model Event {
  id          String        @id @default(uuid())
  title       String
  description String?
  eventDate   DateTime
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  usersEvent  UsersEvent[]
}

model Session {
  id          String   @id @default(uuid())
  title       String
  description String?
  date        DateTime @default(now())
  groupId     String
  group       Groups   @relation(fields: [groupId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model GroupJoinRequest {
  id        String   @id @default(uuid())
  groupName String
  name      String
  phone     String
  message   String?
  status    String   @default("PENDIENTE")
  createdAt DateTime @default(now())

  @@map("group_join_requests")
}

model TeachersService {
  id              String             @id @default(uuid())
  name            String
  number          String?            @unique
  GoToCampement   Boolean            @default(false)
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  teacherId       String
  students        UserServiceSocial[] // via teacherId (legacy)
  studentTeachers StudentTeacher[]
  studentGroups   StudentGroup[]
}

model StudentTeacher {
  id         String            @id @default(uuid())
  studentId  String
  teacherId  String
  student    UserServiceSocial @relation(fields: [studentId], references: [id], onDelete: Cascade)
  teacher    TeachersService   @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  createdAt  DateTime          @default(now())

  @@unique([studentId, teacherId])
  @@map("student_teachers")
}

model StudentGroup {
  id         String             @id @default(uuid())
  name       String
  number     String?            // Número o código del grupo (ej: "01", "A1")
  teacherId  String?
  teacher    TeachersService?   @relation(fields: [teacherId], references: [id], onDelete: SetNull)
  createdAt  DateTime           @default(now())
  updatedAt  DateTime           @updatedAt
  students   UserServiceSocial[]

  @@map("student_groups")
}

model UserServiceSocial {
  id                String            @id @default(uuid())
  name              String
  number            String?           @unique
  GoToCampement     Boolean           @default(false)
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  Gender            Gender
  Documents         String?
  payGotoCampement  Pay               @default(DEBE)
  groupId           String?
  group             StudentGroup?     @relation(fields: [groupId], references: [id], onDelete: SetNull)
  teacherId         String?           // Profesor principal (legacy) - estudiantes pueden tener varios vía studentTeachers
  School            TeachersService?  @relation(fields: [teacherId], references: [id], onDelete: SetNull)
  studentTeachers   StudentTeacher[]
  attendanceRecords AttendanceRecord[]
  moneyCollections  MoneyCollection[]

  @@map("user_service_social")
}

model AttendanceRecord {
  id         String            @id @default(uuid())
  studentId  String
  student    UserServiceSocial @relation(fields: [studentId], references: [id], onDelete: Cascade)
  date       DateTime          @db.Date
  present    Boolean           @default(false)
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt

  @@unique([studentId, date])
  @@map("attendance_records")
}

model MoneyCollection {
  id         String            @id @default(uuid())
  date       DateTime          @db.Date
  amount     Float
  studentId  String
  student    UserServiceSocial @relation(fields: [studentId], references: [id], onDelete: Cascade)
  notes      String?           @db.Text
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt

  @@map("money_collections")
}





